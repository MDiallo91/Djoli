# ─────────────────────────────────────────────────────────────
# School Management System — Variables d'environnement
# Copier ce fichier en .env et adapter les valeurs
# ─────────────────────────────────────────────────────────────

# URL de l'API SaaS (serveur cloud)
SAAS_API_URL=http://localhost:3001

# Mot de passe admin par défaut (changez après le premier login !)
ADMIN_DEFAULT_PASSWORD=admin

# Clé secrète pour les sessions locales (min 32 caractères)
SESSION_SECRET=change-this-to-a-long-random-secret-string
