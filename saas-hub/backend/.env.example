# ─────────────────────────────────────────────────────────────
# SaaS Hub Backend — Variables d'environnement
# Copier ce fichier en .env et adapter les valeurs
# ─────────────────────────────────────────────────────────────

# Port du serveur
PORT=3001

# Base de données
# Pour SQLite (dev) : laissez DATABASE_URL vide
# Pour PostgreSQL   : postgresql://user:pass@host:5432/dbname
DATABASE_URL=

# JWT — OBLIGATOIRE : remplacer par une vraie clé aléatoire (min 64 chars)
JWT_SECRET=CHANGE-THIS-TO-A-REAL-SECRET-MINIMUM-64-CHARACTERS-LONG-PLEASE

# Durée de validité du token JWT (ex: 3d, 7d, 24h)
JWT_EXPIRES_IN=3d

# Environnement
NODE_ENV=development
